{
    "position": "top",
    "height": 28,
    "margin-top": 0,
    "margin-left": 0,
    "margin-right": 0,
    "modules-left": [
        "battery",
        "pulseaudio",
        "network",
        "memory"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "sway/workspaces"
    ],
    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "  Muted",
        "format-icons": {
            "default": ["", ""]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5
    },
    "network": {
        "format-wifi": "  {essid}",
        "format-ethernet": "  Wired",
        "format-disconnected": "  Disconnected",
        "tooltip-format": "  {essid}\n{ipaddr}",
        "on-click": "foot doas nmtui"
    },
    "memory": {
        "format": " {percentage}%",
        "interval": 5
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "  {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "tooltip-format": "{timeTo} {capacity}%"
    },
    "clock": {
        "format": "{:%H:%M  %d/%m}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 1
    },
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}"
    }
}
